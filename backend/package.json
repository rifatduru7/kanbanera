{
  "name": "era-kanban-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "npm run lint -- --fix",
    "check": "npm run typecheck && npm run lint",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute era-kanban-db --file=./schema.sql --local",
    "db:migrate:remote": "wrangler d1 execute era-kanban-db --file=./schema.sql --remote"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "bcrypt-ts": "^8.0.1",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "@eslint/js": "^10.0.1",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.1",
    "wrangler": "^3.80.0"
  }
}
